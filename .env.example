# ==============================================================================
# DOCKVERSE ENTERPRISE - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# --- Server Configuration ---
# Port number for the Express API server to bind to.
PORT=3000
# Node environment mode (development, production, or test).
NODE_ENV=development

# --- MongoDB Database Configuration ---
# Connection URI for the MongoDB storage backend.
MONGODB_URI=mongodb://localhost:27017/dockverse

# --- Docker Daemon Configuration ---
# Local Docker Engine UNIX socket address path.
DOCKER_SOCKET=/var/run/docker.sock
# Remote Docker TCP endpoint host.
DOCKER_HOST=tcp://localhost:2375
# Enable/disable TLS socket validation.
DOCKER_TLS_VERIFY=0
# Certificate folder path for TLS handshakes.
DOCKER_CERT_PATH=

# --- Enterprise Auditing & Polling Settings ---
# Log output level (error, warn, info, verbose, debug).
LOG_LEVEL=info
# Default React Query UI poll interval (in milliseconds).
DEFAULT_POLL_INTERVAL=5000
# Asynchronous operation lifecycle timeout limit (in milliseconds).
OPERATION_TIMEOUT=60000

# --- General Metadata ---
APP_NAME=DockVerse
APP_VERSION=1.0.0-rc1
